{
  "name": "itsme",
  "version": "0.0.3",
  "description": "Long-term memory plugin for agent IDEs — remember / ask / status",
  "author": {
    "name": "coxon",
    "url": "https://github.com/coxon/itsme"
  },
  "homepage": "https://github.com/coxon/itsme",
  "keywords": ["memory", "mcp", "mempalace", "aleph"],
  "mcpServers": {
    "itsme": {
      "command": "uv",
      "args": [
        "run",
        "--project",
        "${CLAUDE_PLUGIN_ROOT}",
        "python",
        "-m",
        "itsme.mcp.server"
      ],
      "env": {
        "DEEPSEEK_API_KEY": "${DEEPSEEK_API_KEY}",
        "ITSME_LLM_MODEL": "${ITSME_LLM_MODEL}",
        "ITSME_MEMPALACE_COMMAND": "${ITSME_MEMPALACE_COMMAND}",
        "MEMPALACE_PALACE_PATH": "${MEMPALACE_PALACE_PATH}",
        "ITSME_ALEPH_ROOT": "${ITSME_ALEPH_ROOT}"
      }
    }
  },
  "hooks": {
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/cc/before-exit.sh\"",
            "timeout": 15
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/cc/before-compact.sh\"",
            "timeout": 15
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/cc/context-pressure.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/cc/context-pressure.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
